# ============================================================
# PROD environment — taa-snowflake-pipeline
# ============================================================
# Populated automatically by the deploy GitHub Action from
# GitHub Environment secrets (environment: prod).
#
# deploy.py reads this file when invoked with: --env prod
# ============================================================

SNOWFLAKE_ACCOUNT=<prod-account-identifier>
SNOWFLAKE_USER=<prod-service-account>
SNOWFLAKE_ROLE=<prod-deployment-role>

SNOWFLAKE_AUTHENTICATOR=private_key_jwt
SNOWFLAKE_PRIVATE_KEY_PATH=/tmp/snowflake_key.p8   # written by CI from secret

SNOWFLAKE_DATABASE=<prod-database>
SNOWFLAKE_SCHEMA=<prod-schema>
SNOWFLAKE_WAREHOUSE=<prod-warehouse>
