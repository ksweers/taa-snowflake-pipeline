# ============================================================
# DEV environment — taa-snowflake-pipeline
# ============================================================
# DO NOT commit real credentials. Copy this file to a local
# override and populate the values there, OR configure
# GitHub Environment secrets for CI/CD deployments.
#
# deploy.py reads this file when invoked with: --env dev
# ============================================================

SNOWFLAKE_ACCOUNT=<your-account-identifier>        # e.g. xy12345.us-east-1
SNOWFLAKE_USER=<your-service-account-or-username>
SNOWFLAKE_ROLE=SYSADMIN                             # or your deployment role

# --- Authentication: choose ONE block ---

# Option A: Key-pair (recommended for CI/CD)
SNOWFLAKE_AUTHENTICATOR=private_key_jwt
SNOWFLAKE_PRIVATE_KEY_PATH=~/.snowflake/dev_rsa_key.p8

# Option B: SSO / browser (local dev only)
# SNOWFLAKE_AUTHENTICATOR=externalbrowser

# Option C: Password (not recommended)
# SNOWFLAKE_AUTHENTICATOR=snowflake
# SNOWFLAKE_PASSWORD=<password>

# --- Target objects ---
SNOWFLAKE_DATABASE=onelake_test
SNOWFLAKE_SCHEMA=kyle
SNOWFLAKE_WAREHOUSE=WH_DS_AUTOMATION_TST
