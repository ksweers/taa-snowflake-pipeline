# ============================================================
# STAGING environment — taa-snowflake-pipeline
# ============================================================
# Populated automatically by the deploy GitHub Action from
# GitHub Environment secrets (environment: staging).
#
# deploy.py reads this file when invoked with: --env staging
# ============================================================

SNOWFLAKE_ACCOUNT=<staging-account-identifier>
SNOWFLAKE_USER=<staging-service-account>
SNOWFLAKE_ROLE=<staging-deployment-role>

SNOWFLAKE_AUTHENTICATOR=private_key_jwt
SNOWFLAKE_PRIVATE_KEY_PATH=/tmp/snowflake_key.p8   # written by CI from secret

SNOWFLAKE_DATABASE=<staging-database>
SNOWFLAKE_SCHEMA=<staging-schema>
SNOWFLAKE_WAREHOUSE=<staging-warehouse>
